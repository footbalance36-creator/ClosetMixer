# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit secrets.

# Play Store service-account JSON (created in Google Play Console → Setup → API access)
PLAY_STORE_JSON_KEY=fastlane/play-store-credentials.json

# Android release keystore
KEYSTORE_PATH=keystore/release.jks
KEYSTORE_PASSWORD=changeme
KEY_ALIAS=closetmixer
KEY_PASSWORD=changeme
